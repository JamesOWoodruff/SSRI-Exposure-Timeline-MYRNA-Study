library(tidyverse)
library(readxl)

# ── 0. Load ───────────────────────────────────────────────────────────────────
Medication_Data <- read_excel(
  "C:/Users/jowjo/OneDrive/Desktop/ALL NYSPI/Data for Nicolo/Med Exposures Github Coded/Medication Data.xlsx"
)

results_dir <- "C:/Users/jowjo/OneDrive/Desktop/ALL NYSPI/Work for Adi/Bayley Bitsea Plots 052726/Predicting BITSEABAYLEY by phq and ssri"

END_OF_PREGNANCY <- 40
W_T1T2_START <-  0; W_T1T2_END <- 26
W_T3_START   <- 27; W_T3_END   <- 40

ssri_equiv <- c(
  "citalopram"   = 20,
  "escitalopram" = 10,
  "fluoxetine"   = 20,
  "paroxetine"   = 20,
  "sertraline"   = 50
)

# ── 1. Pivot wide → long ──────────────────────────────────────────────────────
rx_slots <- 1:7

long <- map_dfr(rx_slots, function(i) {
  name_col  <- paste0("name_rx",      i)
  class_col <- paste0("class_rx",     i)
  start_col <- paste0("pma_start_rx", i)
  stop_col  <- paste0("pma_stop_rx",  i)
  dose_col  <- paste0("dose_rx",      i)

  Medication_Data %>%
    select(
      redcap_id,
      drug  = all_of(name_col),
      class = all_of(class_col),
      start = all_of(start_col),
      stop  = all_of(stop_col),
      dose  = all_of(dose_col)
    ) %>%
    mutate(slot = i)
}) %>%
  filter(!is.na(drug), drug != "")

# ── 2. Filter to SSRI only ────────────────────────────────────────────────────
ssri_names <- names(ssri_equiv)

ssri_long <- long %>%
  mutate(
    is_ssri_class = str_detect(tolower(class), "isrs"),
    is_ssri_name  = tolower(drug) %in% ssri_names,
    is_ssri       = is_ssri_class | is_ssri_name
  ) %>%
  filter(is_ssri) %>%
  select(redcap_id, slot, drug, start, stop, dose)

# ── 3. Parse start / stop ─────────────────────────────────────────────────────
parse_time <- function(x) {
  x <- str_trim(as.character(x))
  if (x %in% c("", "NA", "?", "UNK", "UNK-during pregnancy",
                "UNK- beginning of pregnancy", "UNK-Unsure if taken")) return(NA_real_)
  suppressWarnings(as.numeric(x))
}

ssri_long <- ssri_long %>%
  mutate(
    start_num = map_dbl(start, parse_time),
    stop_num  = map_dbl(stop,  parse_time),
    start_num = if_else(is.na(start_num), 0,                  start_num),
    stop_num  = if_else(is.na(stop_num),  END_OF_PREGNANCY,   stop_num),
    start_num = if_else(start_num < 0,    0,                  start_num)
  )

# ── 4. Parse doses ────────────────────────────────────────────────────────────
parse_dose <- function(x) {
  x <- str_trim(tolower(as.character(x)))
  if (x %in% c("", "na", "unk")) return(NA_real_)
  nums <- as.numeric(unlist(str_extract_all(x, "[0-9]+\\.?[0-9]*")))
  if (length(nums) == 0) return(NA_real_)
  base <- if (length(nums) >= 2 && str_detect(x, "[0-9]\\s*-\\s*[0-9]")) {
    mean(nums[1:2])
  } else { nums[1] }
  mult <- case_when(
    str_detect(x, "bid|2\\s*x|x\\s*2|twice")          ~ 2,
    str_detect(x, "tid|3\\s*x|x\\s*3|three times")    ~ 3,
    str_detect(x, "qid|4\\s*x|x\\s*4|four times")     ~ 4,
    str_detect(x, "1 jour sur 2|every other day|q2d") ~ 0.5,
    TRUE                                               ~ 1
  )
  base * mult
}

ssri_long <- ssri_long %>%
  mutate(
    dose_daily_mg = map_dbl(dose, parse_dose),
    dose_flag     = is.na(dose_daily_mg)
  )

# ── 5. Citalopram equivalents ─────────────────────────────────────────────────
ssri_long <- ssri_long %>%
  mutate(
    drug_lower = tolower(str_trim(drug)),
    ref_dose = case_when(
      str_detect(drug_lower, "citalopram")   ~ ssri_equiv["citalopram"],
      str_detect(drug_lower, "escitalopram") ~ ssri_equiv["escitalopram"],
      str_detect(drug_lower, "fluoxetine")   ~ ssri_equiv["fluoxetine"],
      str_detect(drug_lower, "paroxetine")   ~ ssri_equiv["paroxetine"],
      str_detect(drug_lower, "sertraline")   ~ ssri_equiv["sertraline"],
      TRUE                                   ~ NA_real_
    ),
    cit_equiv_dose = (dose_daily_mg / ref_dose) * ssri_equiv["citalopram"]
  )

# ── 6. Deduplicate ────────────────────────────────────────────────────────────
ssri_long <- ssri_long %>%
  distinct(redcap_id, drug_lower, start_num, stop_num, dose_daily_mg, .keep_all = TRUE)

# ── 7. Resolve overlapping intervals ─────────────────────────────────────────
resolve_overlaps <- function(df) {
  breaks <- sort(unique(c(df$start_num, df$stop_num)))
  if (length(breaks) < 2) return(
    tibble(start_num = df$start_num[1], stop_num = df$stop_num[1],
           cit_equiv_dose = df$cit_equiv_dose[1])
  )
  intervals <- tibble(
    start_num = breaks[-length(breaks)],
    stop_num  = breaks[-1]
  )
  intervals %>%
    mutate(
      cit_equiv_dose = map2_dbl(start_num, stop_num, function(s, e) {
        mid <- (s + e) / 2
        active <- df %>% filter(start_num <= mid, stop_num > mid)
        if (nrow(active) == 0) return(NA_real_)
        max(active$cit_equiv_dose, na.rm = TRUE)
      })
    ) %>%
    filter(!is.na(cit_equiv_dose), stop_num > start_num)
}

timeline <- ssri_long %>%
  filter(!is.na(cit_equiv_dose)) %>%
  group_by(redcap_id) %>%
  group_modify(~ resolve_overlaps(.x)) %>%
  ungroup()

# ── 8. Compute window-specific exposure scores ────────────────────────────────
# For each window, clip interval to window boundaries before summing
clip_and_sum <- function(tl, win_start, win_end) {
  tl %>%
    mutate(
      # clip interval to window
      seg_start = pmax(start_num, win_start),
      seg_end   = pmin(stop_num,  win_end),
      duration  = pmax(seg_end - seg_start, 0)
    ) %>%
    filter(duration > 0) %>%
    group_by(redcap_id) %>%
    summarise(exposure = sum(cit_equiv_dose * duration, na.rm = TRUE),
              .groups = "drop")
}

scores_total <- timeline %>%
  mutate(duration = stop_num - start_num) %>%
  group_by(redcap_id) %>%
  summarise(ssri_dose_total = sum(cit_equiv_dose * duration, na.rm = TRUE),
            .groups = "drop")

scores_t1t2 <- clip_and_sum(timeline, W_T1T2_START, W_T1T2_END) %>%
  rename(ssri_dose_t1t2 = exposure)

scores_t3 <- clip_and_sum(timeline, W_T3_START, W_T3_END) %>%
  rename(ssri_dose_t3 = exposure)

# ── 9. Combine ────────────────────────────────────────────────────────────────
scores_combined <- Medication_Data %>%
  select(redcap_id) %>%
  distinct() %>%
  mutate(redcap_id = as.character(redcap_id)) %>%
  left_join(scores_total, by = "redcap_id") %>%
  left_join(scores_t1t2,  by = "redcap_id") %>%
  left_join(scores_t3,    by = "redcap_id") %>%
  # zero-fill: participants in file but no SSRI exposure scored = 0
  mutate(across(starts_with("ssri_dose"), ~ replace_na(., 0)))

# ── 10. Descriptives ──────────────────────────────────────────────────────────
cat("=== Window-Specific SSRI Exposure Scores (non-zero only) ===\n\n")

for (col in c("ssri_dose_total", "ssri_dose_t1t2", "ssri_dose_t3")) {
  vals <- scores_combined %>%
    filter(.data[[col]] > 0) %>%
    pull(.data[[col]])
  cat(col, "| N non-zero:", length(vals), "\n")
  cat("  Mean:", round(mean(vals), 1),
      "| SD:", round(sd(vals), 1),
      "| Median:", round(median(vals), 1),
      "| IQR:", round(quantile(vals, 0.25), 1),
      "-", round(quantile(vals, 0.75), 1),
      "| Min:", round(min(vals), 1),
      "| Max:", round(max(vals), 1), "\n\n")
}

# ── 11. Correlation between window scores ─────────────────────────────────────
cat("=== Correlations among dose scores (non-zero participants) ===\n")
cor_dat <- scores_combined %>%
  filter(ssri_dose_total > 0) %>%
  select(ssri_dose_total, ssri_dose_t1t2, ssri_dose_t3)
print(round(cor(cor_dat, use = "complete.obs"), 3))

