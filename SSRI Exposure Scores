    window == "ssri_dose_t3"    ~ "T3 (27\u201340 wk)"
  ),
  window = factor(window, levels = c(
    "Total (0\u201340 wk)", "T1\u2013T2 (0\u201326 wk)", "T3 (27\u201340 wk)"
  )))

p_dist <- ggplot(plot_dat, aes(x = exposure, fill = window)) +
  geom_histogram(bins = 20, color = "white", alpha = 0.85) +
  geom_vline(data = plot_dat %>%
               group_by(window) %>%
               summarise(med = median(exposure), .groups = "drop"),
             aes(xintercept = med),
             linetype = "dashed", color = "black", linewidth = 0.7) +
  facet_wrap(~ window, scales = "free_x", nrow = 1) +
  scale_fill_manual(values = c(
    "Total (0\u201340 wk)"    = "#9B7DB5",
    "T1\u2013T2 (0\u201326 wk)" = "#7B9EC9",
    "T3 (27\u201340 wk)"     = "#4CAF8E"
  ), guide = "none") +
  labs(
    title    = "Distribution of Window-Specific SSRI Cumulative Exposure",
    subtitle = "Citalopram-normalized dose \u00d7 weeks | SSRI participants only | dashed line = median",
    x = "Cumulative Exposure (citalopram-equivalent dose-weeks)",
    y = "Count"
  ) +
  theme_bw(base_size = 13) +
  theme(
    plot.background  = element_rect(fill = "white", color = NA),
    strip.background = element_blank(),
    strip.text       = element_text(face = "bold", size = 12),
    panel.grid.minor = element_blank(),
    plot.title       = element_text(face = "bold", color = "#2A9D8F", size = 14),
